# Websoft9 Container Configuration
# This file is used by docker-compose.yml

# Container name
CONTAINER_NAME=websoft9

# Port mappings
HTTP_PORT=9091

# Image
IMAGE_TAG=latest

# Volumes
WEBSOFT9_DATA_PATH=/websoft9/data

# Restart policy
RESTART_POLICY=unless-stopped

# Admin credentials (can be customized)
ADMIN_USER=websoft9
ADMIN_PASSWORD=websoft9
