# Websoft9 Cockpit Container Configuration
# This file is used by docker-compose.yml

# Container name
CONTAINER_NAME=websoft9-cockpit

# Port mappings
HTTP_PORT=9091

# Image
IMAGE_TAG=latest

# Volumes
COMPOSE_DATA_PATH=/data/compose
PORTAINER_DATA_VOLUME=cockpit_portainer_data

# Restart policy
RESTART_POLICY=unless-stopped

# Admin credentials (can be customized)
ADMIN_USER=websoft9
ADMIN_PASSWORD=websoft9
