# Websoft9 environment configuration
# Copy to .env and customize before running a compose file directly:
# docker compose -f docker-compose.yml up -d
# docker compose -f docker-compose.dev.yml up -d --build

# Runtime data root on the host.
# Must stay a host bind mount so Portainer and the host Docker daemon resolve
# the same /data/portainer/compose/... paths for Git-backed stack bind mounts.
WEBSOFT9_DATA_ROOT=/data

CONSOLE_PORT=9000
NETWORK_NAME=websoft9

# Image settings (production)
IMAGE_REPO=websoft9dev/websoft9
IMAGE_TAG=latest

# Optional overrides (uncomment per deployment target if needed)
# CONTAINER_NAME=websoft9

