# Websoft9 environment configuration
# Copy to .env and customize before running: docker compose up -d

CONSOLE_PORT=9000
NETWORK_NAME=websoft9

# Image settings (production)
IMAGE_REPO=websoft9dev/websoft9
IMAGE_TAG=latest

# Build args (development only — used by docker-compose.dev.yml)
WEBSOFT9_PRODUCT_VERSION=
WEBSOFT9_PRODUCT_EDITION_KEY=free

